# Groq API (fallback)
GROQ_API_KEY=

# Hugging Face API (primary - DeepSeek-R1)
HF_TOKEN=
HF_MODEL=deepseek-ai/DeepSeek-R1

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage Configuration
JOBS_FILE_PATH=data/jobs.json
RESUME_FILE_PATH=data/resume.txt
USER_PREFS_FILE_PATH=data/user_prefs.json

# Search Settings
DEFAULT_MAX_JOBS=20
DEFAULT_MIN_MATCH_SCORE=50
DEFAULT_FRESHNESS_HOURS=24
SEARCH_TIMEOUT=60

# LLM Settings (if using Groq fallback)
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048